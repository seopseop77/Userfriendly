# Copy this file to `.env` and adjust for your local environment.
# 환경변수 접두사는 `LLMTRACK_*`. 예외는 프록시를 Claude Code에 가리키기 위한
# 표준 `ANTHROPIC_BASE_URL` 정도.

# 프록시가 듣는 주소/포트 (기본: 127.0.0.1:8787). 외부 바인딩 금지.
LLMTRACK_HOST=127.0.0.1
LLMTRACK_PORT=8787

# 업스트림(진짜 Anthropic API)
LLMTRACK_UPSTREAM_BASE_URL=https://api.anthropic.com

# 수집 레벨: L0 | L1 | L2  (기본 L1; L2는 연구 참여자 opt-in)
LLMTRACK_CONTENT_LEVEL=L1

# 로컬 저장 경로 (미지정 시 ~/.local/share/llm-tracker/buffer.sqlite)
# LLMTRACK_DB_PATH=

# 중앙 Ingest API (Phase 1 이후; 비우면 로컬에만 남음)
# LLMTRACK_INGEST_URL=
# LLMTRACK_INGEST_TOKEN=

# 로깅 레벨
LLMTRACK_LOG_LEVEL=INFO

# Claude Code에 주입할 값 (참고용 — 쉘에서 직접 export)
# export ANTHROPIC_BASE_URL=http://127.0.0.1:8787
