# Copy this file to `.env` and adjust for your local environment.
# Env-var prefix is `LLMTRACK_*`. The exception is `ANTHROPIC_BASE_URL`,
# which Claude Code expects in order to point at this proxy.

# Address the proxy listens on (default: 127.0.0.1:8787). Never bind externally.
LLMTRACK_HOST=127.0.0.1
LLMTRACK_PORT=8787

# Upstream (the real Anthropic API)
LLMTRACK_UPSTREAM_BASE_URL=https://api.anthropic.com

# Content level: L0 | L1 | L2 | L3 (default L1; L2/L3 require user opt-in)
LLMTRACK_CONTENT_LEVEL=L1

# Local storage path (default: ~/.local/share/llm-tracker/buffer.sqlite)
# LLMTRACK_DB_PATH=

# Central ingest API (Phase 2+; if unset, data stays local)
# LLMTRACK_INGEST_URL=
# LLMTRACK_INGEST_TOKEN=

# Logging level
LLMTRACK_LOG_LEVEL=INFO

# Reminder: Claude Code points here via this env var
# export ANTHROPIC_BASE_URL=http://127.0.0.1:8787
