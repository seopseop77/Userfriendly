# Copy this file to `.env` and fill in the values you need. The proxy
# loads `.env` from its working directory at startup
# (`packages/llm_tracker/src/llm_tracker/proxy/app.py:lifespan`). A
# shell-exported value still wins over the file â€” `.env` is for
# convenience, not authority. Both files are searched per the standard
# python-dotenv resolution.
#
# `.env` itself is gitignored (see .gitignore). Never commit a populated
# `.env`: the supabase_sink key below is a service_role key with full
# database write access. `.env.example` (this file) is safe to commit.

# -- Core proxy ---------------------------------------------------------

# Deployment mode: L (local-only, no plugin egress) | A (audit-light) |
# R (research). Default: L. Mode R is required for `supabase_sink` to
# load. ADR-0006.
LLMTRACK_MODE=L

# Process-wide user opt-in (ADR-0016). Lifts Mode R's content ceiling
# from L1 (metadata only) to L3 (full prompt + response). Required for
# supabase_sink to actually upload prompt/response text.
# `1` / `true` / `yes` -> True; `0` / `false` / `no` (default) -> False.
LLMTRACK_USER_OPTED_IN=0

# Proxy listen address (defaults to 127.0.0.1:8787). Don't bind to a
# wider interface â€” the admin route under `/admin/*` has no auth.
# LLMTRACK_PROXY_HOST=127.0.0.1
# LLMTRACK_PROXY_PORT=8787

# Local SQLite path (defaults to `./var/llm_tracker.db`).
# LLMTRACK_DB_URL=sqlite+aiosqlite:///./var/llm_tracker.db

# Comma-separated plugin manifest names to skip at load time (ADR-0013).
# Useful for disabling a plugin without uninstalling it.
# LLMTRACK_PLUGINS_DISABLED=token_counter,supabase_sink

# -- supabase_sink plugin (Mode R reference upload sink) ---------------

# PostgREST insert endpoint. Must match the manifest's
# `egress_destinations` entry exactly â€” EgressGuard does no URL fuzzing.
# LLMTRACK_PLUGIN_SUPABASE_SINK_URL=https://<project-ref>.supabase.co/rest/v1/exchanges

# Supabase service_role key (Project Settings -> API -> service_role).
# Bypasses RLS by Postgres design â€” keep it out of any client-side
# context. Read fresh from env each `submit` call (the plugin's
# `headers_factory`); rotation just needs a proxy restart.
# LLMTRACK_PLUGIN_SUPABASE_SINK_KEY=<paste_service_role_key>

# -- Claude Code wiring (informational) --------------------------------

# When running Claude Code through the proxy, point its API base at the
# proxy. `claude-manage` sets this for the spawned subprocess
# automatically; if you're invoking `claude` yourself, export it.
# export ANTHROPIC_BASE_URL=http://127.0.0.1:8787
