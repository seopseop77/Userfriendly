# Self-host environment for docker-compose.yml (ADR-0042).
# Copy to `.env` (gitignored) and fill in. docker compose auto-loads `.env`.

# Password for the local Postgres `llm_tracker` superuser. Pick a strong
# value; it never leaves the box (Postgres is not published off the host).
POSTGRES_PASSWORD=change-me

# Public HTTPS URL the signup app hands to participants for
# `claude-manage setup --server-url ...`. This is the *server's* Cloudflare
# Tunnel hostname (not the signup app's own hostname).
PUBLIC_SERVER_URL=https://llm-tracker.example.com

# Cloudflare Turnstile (anti-bot) for the public signup form. Optional:
# leave both blank to disable the captcha; set both to enforce it. Create
# a widget at Cloudflare dashboard → Turnstile → add the signup hostname,
# then paste the site key + secret here.
LLMTRACK_TURNSTILE_SITE_KEY=
LLMTRACK_TURNSTILE_SECRET=
